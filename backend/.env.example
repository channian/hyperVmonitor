# 複製為 .env 後填入實際值

# ── 資料庫 ────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hv_metrics.db
# 切換 PostgreSQL 時改為：
# DATABASE_URL=postgresql://user:password@host:5432/hv_monitor

# ── Hyper-V 宿主機 WinRM ─────────────────────────────────────
WINRM_USER=administrator
WINRM_PASSWORD=your_password_here
HV_HOSTS=192.168.1.101,192.168.1.102

# ── Email 通知（SMTP）────────────────────────────────────────
SMTP_HOST=mail.company.com
SMTP_PORT=25
SMTP_SENDER_EMAIL=hv-monitor@company.com
SMTP_SENDER_NAME=Hyper-V Monitor
# 收件人（逗號分隔可設多位）
ALERT_EMAIL_IT=it-team@company.com
ALERT_EMAIL_MANAGER=it-manager@company.com
# Dashboard 連結（填入後 Email 底部會附上超連結）
DASHBOARD_URL=http://192.168.1.200:8000

# ── Webhook 推播（可選）──────────────────────────────────────
WEBHOOK_ENABLE=false
WEBHOOK_URL=http://internal-api.company.com/webhook
WEBHOOK_TOKEN=your_token_here
# Body 模板：使用 {{$variable}} 佔位符
# 可用變數：title, severity, status, source, message, timestamp, token
WEBHOOK_BODY_TEMPLATE={"token":"{{$token}}","title":"{{$title}}","content":"{{$message}}"}
# 若需走 Proxy（留空則直連）
WEBHOOK_USE_PROXY=false
WEBHOOK_PROXY_URL=
